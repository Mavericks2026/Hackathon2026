# === Claude ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Cheapest widely-available Anthropic model — great for testing / low-cost use.
# Upgrade to claude-sonnet-4-5-20250929 or claude-opus-4-5 for higher-quality answers.
CLAUDE_MODEL=claude-3-5-haiku-latest
CLAUDE_MAX_TOKENS=1500
# Some newer Claude 4 / extended-thinking models REJECT any temperature != 1 and
# return a "temperature is deprecated" error. The backend auto-detects this and
# retries without the parameter — no action needed. If you switch defaults to
# such a model, you can set this to 1.0 to avoid the extra first-call retry.
CLAUDE_TEMPERATURE=0.2

# === App ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === RAG ===
EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
EMBEDDING_DEVICE=cpu
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=regview_docs
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RAG_TOP_K=5
RAG_FINAL_K=3
# Cosine distance threshold. Lower = closer. Chunks with distance <= this are considered relevant.
RAG_DISTANCE_THRESHOLD=0.55
# Extra safety net: even after threshold-filtering, the TOP-1 chunk must be at
# least this close or we abstain. Lower = stricter. Set 0 to disable.
RAG_TOP_DISTANCE_FLOOR=0.45
# If true and retrieval finds nothing relevant, the API refuses to answer instead
# of falling back to Claude's general knowledge.
RAG_STRICT=true

# === Memory ===
SESSION_DB_URL=sqlite+aiosqlite:///./data/sessions.db
MAX_HISTORY_MESSAGES=50

# === Data dirs ===
DOCUMENTS_DIR=./data/documents
